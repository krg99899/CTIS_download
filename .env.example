# Gemini API key — required for USDM extraction.
# Get a free key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Optional: override the default Gemini model.
# Defaults to gemini-2.5-flash (free tier friendly).
# GEMINI_MODEL=gemini-2.5-flash

# Optional: override the server port (defaults to 3900 locally; Railway/PaaS
# inject PORT automatically).
# PORT=3900
